"""
Portfolio MCP Server
포트폴리오 엑셀 DB를 Claude Desktop에서 자연어로 조회하는 MCP 서버

통신 방식: stdio (Claude Desktop이 이 프로세스를 직접 실행)
데이터:    읽기 전용 — 원본 엑셀을 절대 수정하지 않음
"""

import os
import json
import sys
from pathlib import Path

import pandas as pd
from mcp.server import Server
from mcp.server.stdio import stdio_server
from mcp.types import Tool, TextContent

# ── 설정 ─────────────────────────────────────────────────────────────
# 엑셀 파일 경로: 환경변수로 주입받거나, 이 파일과 같은 폴더의 파일 사용
EXCEL_PATH = os.environ.get(
    "PORTFOLIO_EXCEL_PATH",
    str(Path(__file__).parent / "sample_portfolio.xlsx")
)

# ── 데이터 로더 (읽기 전용) ──────────────────────────────────────────
def load_data() -> pd.DataFrame:
    """엑셀을 읽어 DataFrame 반환. 항상 원본 파일에서 새로 읽음."""
    if not Path(EXCEL_PATH).exists():
        raise FileNotFoundError(f"엑셀 파일을 찾을 수 없습니다: {EXCEL_PATH}")
    df = pd.read_excel(EXCEL_PATH)
    # 숫자 컬럼 타입 정리
    for col in ["투자년도", "투자월", "합계 투자금액(M$)", "당시 투자 Round 금액(M$)", "지분율(%)"]:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")
    return df


def df_to_records(df: pd.DataFrame) -> list[dict]:
    """DataFrame → JSON 직렬화 가능한 dict 리스트 (원본 값 그대로)"""
    records = []
    for _, row in df.iterrows():
        record = {}
        for k, v in row.items():
            if pd.isna(v):
                record[k] = None
            elif isinstance(v, float) and v == int(v):
                record[k] = int(v)
            else:
                record[k] = v
        records.append(record)
    return records


# ── MCP 서버 초기화 ──────────────────────────────────────────────────
app = Server("portfolio-mcp")


# ────────────────────────────────────────────────────────────────────
# Tool 1: search_portfolio
# 다중 조건 필터링 — Claude가 자연어에서 파싱한 파라미터를 받아 정확히 필터
# ────────────────────────────────────────────────────────────────────
@app.list_tools()
async def list_tools() -> list[Tool]:
    return [
        Tool(
            name="search_portfolio",
            description=(
                "【필수】포트폴리오 투자 데이터를 조회할 때 반드시 이 Tool을 호출하세요. "
                "기업명, 섹터, 지역, 라운드, 투자금액, 지분율 등 포트폴리오와 관련된 "
                "모든 검색/조회 질문에 이 Tool을 사용해야 합니다. "
                "Claude 자체 지식이나 추측으로 포트폴리오 데이터를 절대 답변하지 마세요. "
                "모든 파라미터는 선택사항이며, 결과는 원본 데이터 그대로 반환됩니다."
            ),
            inputSchema={
                "type": "object",
                "properties": {
                    "company_name": {
                        "type": "string",
                        "description": "기업명 (부분 일치 검색, 예: '오션'으로 검색하면 '오션벤처스' 매칭)"
                    },
                    "sector": {
                        "type": "string",
                        "description": "투자 분야. 가능한 값: Advanced Materials, AI/SaaS, Bio/Healthcare, Climate Tech, Cloud Infra, Cybersecurity, E-Commerce, EdTech, Fintech, FoodTech, Game, HRTech, Logistics, Media/Content, Mobility, Robotics"
                    },
                    "region": {
                        "type": "string",
                        "description": "투자 지역/국가. 예: 한국, 미국, 싱가포르, 일본, 인도, 베트남, 중국, 독일, 영국, 프랑스, 이스라엘, 인도네시아"
                    },
                    "investment_type": {
                        "type": "string",
                        "enum": ["지분투자", "전환채권"],
                        "description": "투자 유형"
                    },
                    "exit_status": {
                        "type": "string",
                        "enum": ["Y", "N"],
                        "description": "Exit 여부. Y=완료, N=미완료"
                    },
                    "round_info": {
                        "type": "string",
                        "description": "투자 라운드. 예: Seed, Pre-A, Series A, Series B, Series C, Series D, Pre-IPO CB, Series A Bridge"
                    },
                    "year_from": {
                        "type": "integer",
                        "description": "투자 시작 연도 (이 연도 이후, 포함)"
                    },
                    "year_to": {
                        "type": "integer",
                        "description": "투자 종료 연도 (이 연도 이전, 포함)"
                    },
                    "min_total_amount": {
                        "type": "number",
                        "description": "누적 투자금액 최솟값 (M$)"
                    },
                    "max_total_amount": {
                        "type": "number",
                        "description": "누적 투자금액 최댓값 (M$)"
                    },
                    "min_equity": {
                        "type": "number",
                        "description": "지분율 최솟값 (%)"
                    },
                    "max_equity": {
                        "type": "number",
                        "description": "지분율 최댓값 (%)"
                    },
                    "limit": {
                        "type": "integer",
                        "description": "반환할 최대 행 수. 기본값 100",
                        "default": 100
                    }
                },
                "required": []
            }
        ),
        Tool(
            name="get_company_history",
            description=(
                "【필수】특정 기업의 투자 히스토리를 조회할 때 반드시 이 Tool을 호출하세요. "
                "특정 회사명이 언급되고 투자 이력, 라운드 히스토리, 투자 현황을 묻는 "
                "모든 질문에 이 Tool을 사용해야 합니다. "
                "Claude 자체 지식으로 특정 기업 데이터를 절대 답변하지 마세요. "
                "투자년도 순으로 정렬하여 모든 라운드를 반환합니다."
            ),
            inputSchema={
                "type": "object",
                "properties": {
                    "company_name": {
                        "type": "string",
                        "description": "기업명 (정확한 이름 또는 부분 이름)"
                    }
                },
                "required": ["company_name"]
            }
        ),
        Tool(
            name="get_statistics",
            description=(
                "【필수】포트폴리오 통계/집계 질문에 반드시 이 Tool을 호출하세요. "
                "평균, 합계, 개수, 분포 등 숫자 계산이 필요한 모든 질문에 사용합니다. "
                "Claude가 직접 계산하면 오류가 생길 수 있으므로 반드시 이 Tool로 계산하세요. "
                "결과는 서버에서 정확히 계산된 값만 반환합니다."
            ),
            inputSchema={
                "type": "object",
                "properties": {
                    "group_by": {
                        "type": "string",
                        "enum": ["분야", "지역", "투자유형", "당시 투자 Round 정보", "Exit 여부"],
                        "description": "집계 기준 컬럼"
                    },
                    "metric": {
                        "type": "string",
                        "enum": ["count_companies", "sum_amount", "avg_amount", "avg_equity", "count_rows"],
                        "description": (
                            "집계 방식. "
                            "count_companies=포트폴리오사 수, "
                            "sum_amount=누적 투자금액 합계, "
                            "avg_amount=평균 투자금액, "
                            "avg_equity=평균 지분율, "
                            "count_rows=투자 건수"
                        )
                    },
                    "sector": {
                        "type": "string",
                        "description": "특정 섹터만 필터링 (선택사항)"
                    },
                    "region": {
                        "type": "string",
                        "description": "특정 지역만 필터링 (선택사항)"
                    }
                },
                "required": ["group_by", "metric"]
            }
        ),
        Tool(
            name="get_portfolio_summary",
            description=(
                "【필수】포트폴리오 전체 현황, 요약, 개요를 물을 때 반드시 이 Tool을 호출하세요. "
                "'포트폴리오 보여줘', '전체 현황', '몇 개사야' 같은 질문 모두 포함됩니다. "
                "Claude 자체 지식으로 포트폴리오 규모나 현황을 절대 답변하지 마세요."
            ),
            inputSchema={
                "type": "object",
                "properties": {},
                "required": []
            }
        ),
    ]


# ── Tool 핸들러 ───────────────────────────────────────────────────────
@app.call_tool()
async def call_tool(name: str, arguments: dict) -> list[TextContent]:

    # ── Tool 1: search_portfolio ────────────────────────────────────
    if name == "search_portfolio":
        df = load_data()

        # 필터 적용 (각 조건은 독립적으로 AND 적용)
        if arguments.get("company_name"):
            df = df[df["기업명"].str.contains(arguments["company_name"], na=False)]

        if arguments.get("sector"):
            df = df[df["분야"] == arguments["sector"]]

        if arguments.get("region"):
            df = df[df["지역"] == arguments["region"]]

        if arguments.get("investment_type"):
            df = df[df["투자유형"] == arguments["investment_type"]]

        if arguments.get("exit_status"):
            df = df[df["Exit 여부"] == arguments["exit_status"]]

        if arguments.get("round_info"):
            df = df[df["당시 투자 Round 정보"].str.contains(arguments["round_info"], na=False)]

        if arguments.get("year_from") is not None:
            df = df[df["투자년도"] >= arguments["year_from"]]

        if arguments.get("year_to") is not None:
            df = df[df["투자년도"] <= arguments["year_to"]]

        if arguments.get("min_total_amount") is not None:
            df = df[df["합계 투자금액(M$)"] >= arguments["min_total_amount"]]

        if arguments.get("max_total_amount") is not None:
            df = df[df["합계 투자금액(M$)"] <= arguments["max_total_amount"]]

        if arguments.get("min_equity") is not None:
            df = df[df["지분율(%)"] >= arguments["min_equity"]]

        if arguments.get("max_equity") is not None:
            df = df[df["지분율(%)"] <= arguments["max_equity"]]

        limit = arguments.get("limit", 100)
        total = len(df)
        df = df.head(limit)

        result = {
            "total_matched": total,
            "returned": len(df),
            "records": df_to_records(df)
        }
        return [TextContent(type="text", text=json.dumps(result, ensure_ascii=False, indent=2))]

    # ── Tool 2: get_company_history ─────────────────────────────────
    elif name == "get_company_history":
        df = load_data()
        company = arguments["company_name"]

        matched = df[df["기업명"].str.contains(company, na=False)]
        matched = matched.sort_values(["투자년도", "투자월"])

        if matched.empty:
            return [TextContent(type="text", text=json.dumps(
                {"error": f"'{company}'에 해당하는 기업을 찾을 수 없습니다."},
                ensure_ascii=False
            ))]

        found_companies = matched["기업명"].unique().tolist()
        result = {
            "found_companies": found_companies,
            "total_rounds": len(matched),
            "history": df_to_records(matched)
        }
        return [TextContent(type="text", text=json.dumps(result, ensure_ascii=False, indent=2))]

    # ── Tool 3: get_statistics ──────────────────────────────────────
    elif name == "get_statistics":
        df = load_data()

        # 사전 필터
        if arguments.get("sector"):
            df = df[df["분야"] == arguments["sector"]]
        if arguments.get("region"):
            df = df[df["지역"] == arguments["region"]]

        group_by = arguments["group_by"]
        metric = arguments["metric"]

        if metric == "count_companies":
            # 기업명 기준 unique count
            agg = df.groupby(group_by)["기업명"].nunique().reset_index()
            agg.columns = [group_by, "포트폴리오사 수"]

        elif metric == "count_rows":
            agg = df.groupby(group_by).size().reset_index()
            agg.columns = [group_by, "투자 건수"]

        elif metric == "sum_amount":
            # 기업별 최신 누적금액 합산
            latest = df.sort_values(["투자년도", "투자월"]).groupby("기업명").last().reset_index()
            latest_with_group = latest.merge(
                df[["기업명", group_by]].drop_duplicates("기업명"),
                on="기업명"
            )
            agg = latest_with_group.groupby(group_by + "_y" if group_by + "_y" in latest_with_group.columns else group_by)["합계 투자금액(M$)"].sum().reset_index()
            agg.columns = [group_by, "총 투자금액(M$)"]
            agg["총 투자금액(M$)"] = agg["총 투자금액(M$)"].round(1)

        elif metric == "avg_amount":
            agg = df.groupby(group_by)["당시 투자 Round 금액(M$)"].mean().reset_index()
            agg.columns = [group_by, "평균 라운드 투자금액(M$)"]
            agg["평균 라운드 투자금액(M$)"] = agg["평균 라운드 투자금액(M$)"].round(2)

        elif metric == "avg_equity":
            # 지분율 0 제외 (전환채권은 지분율 0)
            df_equity = df[df["지분율(%)"] > 0]
            agg = df_equity.groupby(group_by)["지분율(%)"].mean().reset_index()
            agg.columns = [group_by, "평균 지분율(%)"]
            agg["평균 지분율(%)"] = agg["평균 지분율(%)"].round(2)

        else:
            return [TextContent(type="text", text=json.dumps(
                {"error": f"알 수 없는 metric: {metric}"}, ensure_ascii=False
            ))]

        agg = agg.sort_values(agg.columns[-1], ascending=False)
        result = {
            "group_by": group_by,
            "metric": metric,
            "rows": agg.to_dict("records")
        }
        return [TextContent(type="text", text=json.dumps(result, ensure_ascii=False, indent=2))]

    # ── Tool 4: get_portfolio_summary ───────────────────────────────
    elif name == "get_portfolio_summary":
        df = load_data()

        companies = df["기업명"].nunique()
        sectors = df["분야"].nunique()
        regions = df["지역"].nunique()
        total_rows = len(df)

        exited = df[df["Exit 여부"] == "Y"]["기업명"].nunique()

        # 최신 라운드 기준 누적 투자금액
        latest = df.sort_values(["투자년도", "투자월"]).groupby("기업명").last()
        total_amount = latest["합계 투자금액(M$)"].sum().round(1)

        sector_breakdown = df.groupby("분야")["기업명"].nunique().sort_values(ascending=False).to_dict()
        region_breakdown = df.groupby("지역")["기업명"].nunique().sort_values(ascending=False).to_dict()

        result = {
            "총 포트폴리오사": companies,
            "투자 분야 수": sectors,
            "투자 지역 수": regions,
            "총 투자 건수(라운드)": total_rows,
            "Exit 완료": exited,
            "Exit 미완료": companies - exited,
            "누적 투자금액(M$)": total_amount,
            "분야별 포트폴리오사 수": sector_breakdown,
            "지역별 포트폴리오사 수": region_breakdown,
        }
        return [TextContent(type="text", text=json.dumps(result, ensure_ascii=False, indent=2))]

    else:
        return [TextContent(type="text", text=json.dumps(
            {"error": f"알 수 없는 tool: {name}"}, ensure_ascii=False
        ))]


# ── 진입점 ────────────────────────────────────────────────────────────
if __name__ == "__main__":
    import asyncio

    async def main():
        async with stdio_server() as (read_stream, write_stream):
            await app.run(read_stream, write_stream, app.create_initialization_options())

    asyncio.run(main())